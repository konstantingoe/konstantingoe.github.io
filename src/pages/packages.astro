---
// src/pages/packages.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import AuthorProfile from '../components/AuthorProfile.astro';
import PackageCard from '../components/PackageCard.astro';
import { getCollection } from 'astro:content';
import { sortByDateDesc } from '../utils/siteConfig';

const packages = sortByDateDesc(await getCollection('packages'));
---

<BaseLayout title="Software Packages" currentPage="/packages">
  <section class="container-page">
    <div class="grid md:grid-cols-3 gap-8">
      <aside class="md:col-span-1">
        <AuthorProfile />
      </aside>

      <div class="md:col-span-2">
        <h1 class="text-4xl font-bold mb-2 text-slate-900 dark:text-slate-100">Software Packages</h1>
        <p class="text-slate-600 dark:text-slate-400 mb-8">Research software</p>

        {packages.length === 0 ? (
          <div class="bg-slate-50 dark:bg-slate-800 p-6 rounded border border-slate-200 dark:border-slate-700 text-center text-slate-600 dark:text-slate-400">
            <p>Coming soon. Check back for updates on research software releases.</p>
          </div>
        ) : (
          <div class="grid md:grid-cols-2 gap-6">
            {packages.map((pkg) => (
              <PackageCard item={pkg} />
            ))}
          </div>
        )}
      </div>
    </div>
  </section>
</BaseLayout>
