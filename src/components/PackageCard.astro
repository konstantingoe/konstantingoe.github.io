---
// src/components/PackageCard.astro
import type { CollectionEntry } from 'astro:content';

interface Props {
  item: CollectionEntry<'packages'>;
}

const { item } = Astro.props;
const { title, description, languages, repository, status, featured } = item.data;
const slug = item.slug;
---

<div class={`card ${featured ? 'border-blue-400 border-2' : ''}`}>
  {featured && (
    <span class="inline-block bg-blue-100 text-blue-800 dark:bg-blue-900 dark:text-blue-200 text-xs font-semibold px-2 py-1 rounded mb-2">
      ⭐ Featured
    </span>
  )}
  <a href={`/packages/${slug}`} class="no-underline">
    <h3 class="card-title text-slate-900 dark:text-slate-100">{title}</h3>
  </a>
  <p class="text-sm text-slate-700 dark:text-slate-300 mb-3">{description}</p>

  <div class="flex flex-wrap gap-2 mb-3">
    {languages.map((lang) => (
      <span class="text-xs bg-slate-100 text-slate-700 dark:bg-slate-700 dark:text-slate-300 px-2 py-1 rounded">
        {lang}
      </span>
    ))}
  </div>

  <p class={`text-xs font-semibold mb-3 ${
    status === 'maintained' ? 'text-green-600 dark:text-green-400' :
    status === 'active' ? 'text-blue-600 dark:text-blue-400' :
    'text-yellow-600 dark:text-yellow-400'
  }`}>
    {status}
  </p>

  <div class="flex gap-3">
    {repository && (
      <a href={repository} target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm py-1 px-3">
        Repository
      </a>
    )}
    <a href={`/packages/${slug}`} class="btn text-sm py-1 px-3">
      Details
    </a>
  </div>
</div>
