---
// src/components/PublicationCard.astro
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../utils/siteConfig';

interface Props {
  item: CollectionEntry<'publications'>;
}

const { item } = Astro.props;
const { title, date, venue, paperurl, excerpt } = item.data;
const slug = item.slug;
---

<div class="card">
  <a href={`/publications/${slug}`} class="no-underline">
    <h3 class="card-title text-slate-900 dark:text-slate-100">{title}</h3>
  </a>
  <p class="card-meta">{venue}</p>
  <p class="text-xs text-slate-500 dark:text-slate-400 mb-3">{formatDate(date)}</p>
  {excerpt && (
    <p class="text-sm text-slate-700 dark:text-slate-300 mb-3">{excerpt}</p>
  )}
  <div class="flex gap-3">
    <a href={`/publications/${slug}`} class="btn text-sm py-1 px-3">
      Read More
    </a>
    {paperurl && (
      <a href={paperurl} target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm py-1 px-3">
        Paper
      </a>
    )}
  </div>
</div>
