---
// src/components/AuthorProfile.astro
import { siteConfig } from '../utils/siteConfig';
---

<aside class="mb-8 p-6 bg-slate-50 rounded-lg border border-slate-200">
  <div class="text-center">
    <img
      src={siteConfig.author.avatar}
      alt={siteConfig.author.name}
      class="w-32 h-32 rounded-full mx-auto mb-4 border-4 border-white shadow-md"
    />
    <h2 class="text-xl font-bold text-slate-900">{siteConfig.author.name}</h2>
    <p class="text-sm text-slate-600 mb-2">{siteConfig.author.title}</p>
    <p class="text-sm text-slate-700 mb-4">{siteConfig.author.bio}</p>
    <p class="text-xs text-slate-600 mb-4">
      📍 {siteConfig.author.location}
    </p>

    <div class="flex justify-center gap-3">
      <a
        href={siteConfig.links.github}
        target="_blank"
        rel="noopener noreferrer"
        title="GitHub"
        class="text-blue-600 hover:text-blue-800 no-underline font-semibold"
      >
        GitHub
      </a>
      <span class="text-slate-300">•</span>
      <a
        href={siteConfig.links.arxiv}
        target="_blank"
        rel="noopener noreferrer"
        title="arXiv"
        class="text-blue-600 hover:text-blue-800 no-underline font-semibold"
      >
        arXiv
      </a>
      <span class="text-slate-300">•</span>
      <a
        href={siteConfig.links.googleScholar}
        target="_blank"
        rel="noopener noreferrer"
        title="Google Scholar"
        class="text-blue-600 hover:text-blue-800 no-underline font-semibold"
      >
        Scholar
      </a>
    </div>
  </div>
</aside>
