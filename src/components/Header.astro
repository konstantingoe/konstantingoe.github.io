---
// src/components/Header.astro
import { siteConfig } from '../utils/siteConfig';

interface Props {
  currentPage?: string;
}

const { currentPage } = Astro.props;

const normalizePath = (path?: string) => {
  if (!path) return '';
  return path === '/' ? '/' : path.replace(/\/+$/, '');
};

const activePage = normalizePath(currentPage);

const navItems = [
  { label: 'Publications', href: '/publications' },
  { label: 'Talks', href: '/talks' },
  { label: 'Teaching', href: '/teaching' },
  { label: 'Packages', href: '/packages' },
  { label: 'CV', href: '/cv' },
];
---

<header class="border-b border-slate-200 bg-white sticky top-0 z-50 dark:bg-slate-800 dark:border-slate-700">
  <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="text-2xl font-bold text-slate-900 no-underline hover:text-blue-600 dark:text-slate-100 dark:hover:text-blue-400">
      {siteConfig.author.name}
    </a>

    <ul class="flex gap-6 list-none m-0 p-0">
      {navItems.map((item) => {
        const isActive = activePage === normalizePath(item.href);

        return (
          <li>
            <a
              href={item.href}
              aria-current={isActive ? 'page' : undefined}
              class={`no-underline font-medium transition-colors ${
                isActive
                  ? 'text-blue-600 dark:text-blue-400'
                  : 'text-slate-700 hover:text-blue-600 dark:text-slate-300 dark:hover:text-blue-400'
              }`}
            >
              {item.label}
            </a>
          </li>
        );
      })}
    </ul>
  </nav>
</header>
